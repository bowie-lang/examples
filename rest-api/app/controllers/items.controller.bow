import "@/app/services/items.service.bow" use fetch_all_items

export fn list_items(req) {
  let items = fetch_all_items()
  if type(items) == "error" {
    return {
      "status": 500,
      "body": json_encode({"error": str(items)}),
      "headers": {"Content-Type": "application/json"}
    }
  }
  return {
    "status": 200,
    "body": json_encode({"items": items}),
    "headers": {"Content-Type": "application/json"}
  }
}
